# ===========================================
# LexGuard - Configuración de IA
# ===========================================

# API del clasificador de IA
# URL del endpoint de chat para clasificación de sensibilidad
AI_API_URL=http://localhost:8000/chat

# Timeout en segundos para llamadas a la API de IA
AI_TIMEOUT=10

# API Key (si el servicio requiere autenticación)
# AI_API_KEY=your-api-key-here
